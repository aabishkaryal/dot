#!/bin/bash

# Download YouTube audio into the configured music folder.
# Automatic Beets indexing is currently disabled below.

# Default output directory
OUTPUT_DIR="$HOME/Music/"

# Help message
usage() {
	exit_code="${1:-1}"
	echo "Usage: $(basename $0) [OPTIONS] URL"
	echo "Download music from YouTube URLs"
	echo ""
	echo "Options:"
	echo "  -o DIR    Output directory (default: $OUTPUT_DIR)"
	echo "  -h        Show this help message"
	exit "$exit_code"
}

# Process options
while getopts "o:h" opt; do
	case $opt in
	o) OUTPUT_DIR="$OPTARG" ;;
	h) usage 0 ;;
	?) usage ;;
	esac
done

# Shift past the options
shift $((OPTIND - 1))

# Check if URL is provided
if [ $# -eq 0 ]; then
	echo "Error: Please provide a YouTube URL"
	usage
fi

# Create output directory if it doesn't exist
mkdir -p "$OUTPUT_DIR"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DOWNLOADED_PATHS_FILE="$(mktemp)"
trap 'rm -f "$DOWNLOADED_PATHS_FILE"' EXIT

# Download the audio using yt-dlp
yt-dlp \
	--no-simulate \
	--extract-audio \
	--audio-format mp3 \
	--audio-quality 0 \
	--embed-thumbnail \
	--add-metadata \
	--metadata-from-title "%(artist)s - %(title)s" \
	--parse-metadata "title:%(artist)s - %(title)s" \
	--output "$OUTPUT_DIR/%(title)s.%(ext)s" \
	--print-to-file after_move:filepath "$DOWNLOADED_PATHS_FILE" \
	--no-playlist-reverse \
	--ignore-errors \
	--no-warnings \
	--no-playlist \
	"$@"

download_status=$?
if [ "$download_status" -ne 0 ]; then
	exit "$download_status"
fi

# Automatic Beets indexing is disabled.
# if [ ! -s "$DOWNLOADED_PATHS_FILE" ]; then
# 	echo "Warning: download completed but no downloaded file paths were reported"
# 	exit 0
# fi
#
# index_status=0
# while IFS= read -r downloaded_path; do
# 	if [ -z "$downloaded_path" ]; then
# 		continue
# 	fi
#
# 	"$SCRIPT_DIR/reindex-music" "$downloaded_path" || index_status=$?
# done <"$DOWNLOADED_PATHS_FILE"
#
# if [ "$index_status" -ne 0 ]; then
# 	echo "Warning: Beets indexing failed for one or more downloaded files"
# fi

exit 0
