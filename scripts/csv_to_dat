#!/usr/bin/env python3
"""
Convert CSV file(s) to DAT format using '|' as delimiter.

Usage:
    python csv_to_dat.py input.csv
    python csv_to_dat.py input.csv output.dat
    python csv_to_dat.py *.csv                  # batch convert multiple files
"""

import csv
import sys
from pathlib import Path


def convert_csv_to_dat(input_path: str, output_path: str = None) -> str:
    input_file = Path(input_path)

    if not input_file.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")

    if output_path is None:
        output_file = input_file.with_suffix(".dat")
    else:
        output_file = Path(output_path)

    with open(input_file, newline="", encoding="utf-8") as infile:
        reader = csv.reader(infile)
        rows = list(reader)

    with open(output_file, "w", newline="", encoding="utf-8") as outfile:
        writer = csv.writer(outfile, delimiter="|", quoting=csv.QUOTE_MINIMAL)
        writer.writerows(rows)

    return str(output_file)


def main():
    args = sys.argv[1:]

    if not args:
        print("Usage:")
        print("  python csv_to_dat.py input.csv")
        print("  python csv_to_dat.py input.csv output.dat")
        print("  python csv_to_dat.py file1.csv file2.csv file3.csv")
        sys.exit(1)

    # Two args and second doesn't end in .csv → treat as explicit output path
    if len(args) == 2 and not args[1].endswith(".csv"):
        try:
            out = convert_csv_to_dat(args[0], args[1])
            print(f"✓ {args[0]}  →  {out}")
        except Exception as e:
            print(f"✗ Error: {e}")
            sys.exit(1)
    else:
        # Batch mode: convert each file, auto-naming output
        success, failure = 0, 0
        for path in args:
            try:
                out = convert_csv_to_dat(path)
                print(f"✓ {path}  →  {out}")
                success += 1
            except Exception as e:
                print(f"✗ {path}: {e}")
                failure += 1

        if len(args) > 1:
            print(f"\nDone: {success} converted, {failure} failed.")


if __name__ == "__main__":
    main()
