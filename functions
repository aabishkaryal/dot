#! /bin/zsh
function pomo() {
  if [ -n "$1" ]
  then
    timer $1 && terminal-notifier -title 'Pomodoro' \
      -message 'Pomodoro Timer is up! 😊'\
      -sound Crystal;
  else
    echo "Specify the time for pomo session."
  fi
}

